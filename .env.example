# Neon / PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth — use a long random string in production (required on Vercel or you get Configuration error).
# NEXTAUTH_SECRET and AUTH_SECRET are equivalent; NextAuth picks up either.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# On Vercel Production set NEXTAUTH_URL to your canonical URL e.g. https://your-project.vercel.app

# Cloudflare R2 (S3-compatible). Optional for local dev — image uploads save under public/uploads/.
R2_ACCOUNT_ID=""
R2_BUCKET_NAME=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Example for path-style public URL. Replace with your real public domain/r2.dev URL.
R2_PUBLIC_BASE_URL="https://<ACCOUNT_ID>.r2.cloudflarestorage.com/<BUCKET_NAME>"

# Stripe (optional — stub is used until wired)
STRIPE_SECRET_KEY=""
